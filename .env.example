# Bulk Mail Server — ローカル開発用環境変数
# コピー: cp .env.example .env

NODE_ENV=development
TZ=Asia/Tokyo

# API
API_PORT=8080
API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000
JWT_SECRET=change-me-bulk-mail-jwt-secret-32chars
JWT_EXPIRES_IN=12h

# PostgreSQL
DATABASE_URL=postgresql://bms:bms_secret@localhost:5433/bulkmail

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://bms:bms_secret@localhost:5672
RABBITMQ_QUEUE_SEND=mail.send
RABBITMQ_QUEUE_BOUNCE=mail.bounce
RABBITMQ_QUEUE_COMPLAINT=mail.complaint

# SMTP (Postfix) — MAIL_PROVIDER=smtp のとき使用
MAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM_DEFAULT=noreply@example.local
SMTP_HELO=mail.example.local
# ローカルは Mailpit（:1025 SMTP / :8025 UI）。本番は Postfix:25 または SES

# Amazon SES（MAIL_PROVIDER=ses）
# SES SMTP 認証情報（IAM で作成）または API キー
AWS_REGION=ap-northeast-1
SES_REGION=ap-northeast-1
SES_SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
SES_CONFIGURATION_SET=
# SNS → https://<api>/webhooks/ses に Bounce/Complaint を購読

# S3 (ローカルは MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-northeast-1
S3_BUCKET=bulkmail
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio_secret
S3_FORCE_PATH_STYLE=true

# OpenAI（任意）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 配信・信用スコア閾値
REPUTATION_BOUNCE_WARN=0.05
REPUTATION_COMPLAINT_WARN=0.001
REPUTATION_DELIVERY_WARN=0.95
UNSUBSCRIBE_TOKEN_SECRET=change-me-unsubscribe-secret
